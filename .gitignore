# ============================================
# ReplayHQ .gitignore
# Backend (Go) + Desktop client (Electron/Vite)
# ============================================

# ---------- Node / Electron / Vite ----------
# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
desktop/dist/
desktop/release/
desktop/out/

# Electron-builder cache and intermediate artifacts
desktop/.electron-builder-cache/
desktop/.cache/

# Vite cache
.vite/
desktop/.vite/

# TypeScript build info
*.tsbuildinfo

# Coverage
coverage/
*.lcov
.nyc_output/

# ---------- Go ----------
# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries / coverage
*.test
*.out
coverage.out

# Go workspace files (uncomment if used)
# go.work
# go.work.sum

# ---------- OS / Editor ----------
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json

# JetBrains / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Vim / Emacs
*.swp
*.swo
*~
\#*\#
.\#*

# Logs
*.log
logs/

# Environment files (secrets)
.env
.env.local
.env.*.local
desktop/.env
desktop/.env.local

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup
*.swp

# Local trace / replay artifacts
*.rhq
traces/
sessions/

# Backup files (e.g. *.tsx.backup)
*.backup
